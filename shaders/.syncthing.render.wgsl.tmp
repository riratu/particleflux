struct VertexInput {
    @location(0) position: vec2<f32>,
    @location(1) velocity: vec2<f32>,
    @location(2) life: f32,
    @location(3) size: f32,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) color: vec4<f32>,
};

@vertex
fn vs_main(in: VertexInput) -> VertexOutput {
    var out: VertexOutput;

    out.clip_position = vec4<f32>(in.position, 0.0, 1.0);

  // Make color cycle multiple times based on life
    // Multiply in.life by the number of cycles you want
    var cycledLife = fract(in.life * 40.0);  // 4 cycles
    out.color = vec4<f32>(
           (sin(in.life * 40.0) + 1.0) * 0.5,
           (sin(in.life * 51.0) + 1.0) * 0.5,
           (sin(in.life * 9.0) + 1.0) * 0.5,
           1.0  // Keep alpha fading out linearly
       );

    return out;
}


@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    var color = in.color;

    // Calculate distance from center (0.5, 0.5)
    var center = vec2<f32>(0.5);
    var dist = length(0.5 - center);

    // Create a soft, blurred circle
    // Increase the first value for a larger, softer circle
    color.a *= smoothstep(3, 0.9, dist);

    return color;
}




